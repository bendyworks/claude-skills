#!/usr/bin/env ruby
# frozen_string_literal: true

# linear -- semantic CLI for the Linear GraphQL API.
#
# Reads LINEAR_API_TOKEN from the environment. Stdlib-only (no gems).
# Pretty-prints by default; pass --json for the raw GraphQL response.
#
# Run `linear` with no arguments for the subcommand list.
#
# Structured as a Linear module whose errors raise Linear::Error,
# rescued once to abort in Linear::CLI.run, dispatched behind the
# $PROGRAM_NAME guard so test/linear_test.rb can load this file
# without executing the CLI.

require 'net/http'
require 'json'
require 'uri'
require 'optparse'

module Linear
  Error = Class.new(StandardError)

  API_URI = URI('https://api.linear.app/graphql')

  class Client
    def initialize
      @token = ENV['LINEAR_API_TOKEN']
      raise Error, 'linear: LINEAR_API_TOKEN env var not set' if @token.nil? || @token.empty?
    end

    def query(graphql, variables = {})
      req = Net::HTTP::Post.new(API_URI)
      req['Content-Type'] = 'application/json'
      req['Authorization'] = @token
      req.body = JSON.generate(query: graphql, variables: variables)

      res =
        begin
          Net::HTTP.start(API_URI.hostname, API_URI.port, use_ssl: true) do |http|
            http.request(req)
          end
        rescue SocketError, Timeout::Error, OpenSSL::SSL::SSLError, Errno::ECONNREFUSED => e
          raise Error, "linear: network error: #{e.message}"
        end

      raise Error, "linear: HTTP #{res.code}: #{res.body}" unless res.code == '200'

      payload = JSON.parse(res.body)
      if payload['errors']
        raise Error, "linear: GraphQL error:\n#{JSON.pretty_generate(payload['errors'])}"
      end
      payload
    end

    def resolve_issue(identifier, fields: 'id')
      team_key, number = Linear.parse_identifier!(identifier)

      res = query(<<~GQL, { teamKey: team_key, number: number })
        query($teamKey: String!, $number: Float!) {
          issues(filter: { number: { eq: $number }, team: { key: { eq: $teamKey } } }) {
            nodes { #{fields} }
          }
        }
      GQL
      issue = res.dig('data', 'issues', 'nodes', 0)
      raise Error, "linear: issue #{identifier} not found" unless issue
      issue
    end

    def resolve_project_id(team_id, project_name)
      res = query(<<~GQL, { teamId: team_id })
        query($teamId: String!) {
          team(id: $teamId) { projects(first: 250) { nodes { id name } } }
        }
      GQL
      projects = res.dig('data', 'team', 'projects', 'nodes') || []
      project = projects.find { |p| p['name'] == project_name }
      project ||= projects.find { |p| p['name'].downcase.include?(project_name.downcase) }
      unless project
        available = projects.map { |p| p['name'] }.sort.join("\n  ")
        raise Error, "linear: project #{project_name.inspect} not found.\nAvailable projects:\n  #{available}"
      end
      project['id']
    end

    # Resolves an assignee identifier to a Linear user id. Accepts the literal
    # "me" (the token's own user via viewer), an exact email, or a
    # case-insensitive name substring. Raises on no match or an ambiguous name.
    def resolve_user_id(value)
      if value == 'me'
        res = query('query { viewer { id name email } }')
        user = res.dig('data', 'viewer')
        raise Error, 'linear: could not resolve current user (viewer)' unless user
        return user['id']
      end

      res = query(<<~GQL, { value: value })
        query($value: String!) {
          users(filter: { or: [{ email: { eq: $value } }, { name: { containsIgnoreCase: $value } }] }) {
            nodes { id name email }
          }
        }
      GQL
      users = res.dig('data', 'users', 'nodes') || []
      raise Error, "linear: no user matches #{value.inspect}" if users.empty?
      if users.size > 1
        exact = users.find { |u| u['email'] == value }
        return exact['id'] if exact

        listing = users.map { |u| "#{u['name']} <#{u['email']}>" }.join("\n  ")
        raise Error, "linear: #{value.inspect} matches multiple users:\n  #{listing}"
      end
      users.first['id']
    end
  end

  # A state whose Linear type is "started" (e.g. In Progress) means someone is
  # actively working the issue, so it must have an assignee.
  STARTED_STATE_TYPE = 'started'

  module_function

  def parse_identifier!(identifier)
    team_key, number_str = identifier.split('-', 2)
    if team_key.nil? || number_str.nil?
      raise Error, "linear: identifier must look like ABC-123, got #{identifier.inspect}"
    end
    number =
      begin
        Integer(number_str)
      rescue ArgumentError
        raise Error, "linear: identifier must look like ABC-123, got #{identifier.inspect}"
      end
    [team_key.upcase, number]
  end

  # An option value must not begin with a dash: a mandatory-argument
  # option would otherwise swallow a following flag as its value
  # ('--team --json' parses as team "--json" with no json flag) and
  # silently act on the misread command. A leading-dash lookahead
  # rather than [^-] so an empty value still passes -- it does not
  # begin with a dash, and `--description ''` is how a field is
  # cleared. Anchored end to end to state explicitly the whole-argument
  # match optparse requires of acceptance patterns.
  VALUE_NOT_FLAG = /\A(?!-).*\z/m

  # Returns the leftover positionals. The hint rides on parse failures
  # for subcommands whose accepted shape is not obvious from the flag
  # list alone.
  def parse_options(args, banner, hint: nil)
    parser = OptionParser.new do |o|
      o.banner = banner
      yield o
    end
    # permute, not parse: #parse stops at the first positional while
    # POSIXLY_CORRECT is set, which would turn every flag typed after
    # an identifier into an ignored positional on those machines.
    parser.permute(args)
  rescue OptionParser::ParseError => e
    raise Error, "linear: #{e.message}#{hint ? " #{hint}" : ''}"
  end

  # Declares a value-taking option carrying both guards every such
  # option needs, so no declaration can forget either. VALUE_NOT_FLAG
  # refuses a leading-dash value; the seen flag refuses a repeat --
  # last-one-wins would silently discard the first value, the same
  # dropped-input shape as a stray positional and worse when the
  # surviving value aims the command at a different issue or project
  # than the one typed first. The flag name is read off the spec so it
  # cannot drift from the option it labels. Switches (--json, --all)
  # stay on plain o.on: repeating one discards nothing.
  def value_option(parser, spec, *desc)
    flag = spec.split(/[ =]/, 2).first
    seen = false
    parser.on(spec, VALUE_NOT_FLAG, *desc) do |value|
      raise Error, "linear: duplicate #{flag}" if seen

      seen = true
      yield value
    end
  end

  # Returns the first `count` positionals, refusing any beyond them and
  # -- when `usage` is given -- refusing fewer. A stray positional
  # means part of the typed command was not understood, and dropping it
  # silently lets the command act on half of what was typed:
  # `update ABC-1 ABC-2 --state Done` used to move ABC-1 alone. Strays
  # are inspect-quoted because a mis-quoted shell line can leave one
  # containing spaces, which a bare token would read as two.
  def take_positionals!(rest, count, usage = nil)
    extras = rest.drop(count)
    raise Error, "linear: unexpected extra arguments: #{extras.map(&:inspect).join(', ')}" unless extras.empty?

    taken = rest.first(count)
    raise Error, usage if usage && taken.size < count

    taken
  end

  # Reads clearly at the zero-positional subcommands, where the whole
  # point of the call is the side effect of rejecting any positional.
  def reject_positionals!(rest)
    take_positionals!(rest, 0)
  end

  # Refuses two sources for one value. Offering a value both inline and
  # from a file (or as a positional and a flag) forces the code to keep
  # whichever it reads first and silently drop the rest -- the same
  # dropped-input shape as a repeated option. `sources` maps each way's
  # label to whether it was given; more than one given is the conflict.
  # An empty inline value still counts as given (clearing a field is a
  # deliberate act), so callers pass presence, not truthiness of content.
  def reject_conflicting_sources!(sources)
    given = sources.select { |_label, present| present }.keys
    return if given.size < 2

    # "a and b" for two, "a, b, and c" for the comment subcommand's
    # three-way message sources, so the rare all-three error still reads.
    list = given.size == 2 ? given.join(' and ') : "#{given[0..-2].join(', ')}, and #{given.last}"
    raise Error, "linear: #{list} are mutually exclusive"
  end

  # Reads a --*-file option's path, refusing a missing file with the
  # option's own name rather than letting File.read escape as a raw
  # Errno backtrace.
  def read_file_option!(path, flag)
    raise Error, "linear: #{flag} not found: #{path}" unless File.exist?(path)

    File.read(path)
  end

  # Base 10 explicitly: bare Integer() honours the literal prefixes, so
  # a typed --limit 010 would mean eight and --limit 0x10 sixteen.
  # Nobody typing a page size means either of those.
  def parse_limit(value)
    limit =
      begin
        Integer(value, 10)
      rescue ArgumentError
        raise Error, "linear: --limit must be an integer, got #{value.inspect}"
      end
    raise Error, "linear: --limit must be greater than zero, got #{value.inspect}" unless limit.positive?

    limit
  end

  ISSUE_CORE_FIELDS = <<~GQL
    id identifier title description url
    state { name }
    assignee { name email }
    team { key name }
    project { name }
    parent { identifier title }
    children { nodes { identifier title state { name } } }
  GQL

  ISSUE_COMMENT_FIELDS = <<~GQL
    comments(first: 100) { nodes { id body createdAt user { name } } }
  GQL

  def print_issue(issue, include_comments:)
    puts "#{issue['identifier']} [#{issue.dig('state', 'name')}] #{issue['title']}"
    team = issue.dig('team', 'name') || issue.dig('team', 'key') || '-'
    project = issue.dig('project', 'name') || '-'
    puts "Team: #{team} | Project: #{project}"
    assignee = issue.dig('assignee', 'name')
    puts "Assignee: #{assignee || '(unassigned)'}"
    if (parent = issue['parent'])
      puts "Parent: #{parent['identifier']} #{parent['title']}"
    end
    children = issue.dig('children', 'nodes') || []
    unless children.empty?
      puts 'Children:'
      children.each { |c| puts "  #{c['identifier']} [#{c.dig('state', 'name')}] #{c['title']}" }
    end
    puts "URL: #{issue['url']}" if issue['url']
    puts
    body = issue['description']
    puts(body && !body.empty? ? body : '(no description)')

    return unless include_comments

    comments = issue.dig('comments', 'nodes') || []
    puts
    puts "Comments (#{comments.size}):"
    comments.each { |c| print_comment(c) }
  end

  def print_comment(comment)
    name = comment.dig('user', 'name') || 'unknown'
    date = (comment['createdAt'] || '')[0, 10]
    id = comment['id']
    puts "  [#{name}, #{date}]#{id ? " (id: #{id})" : ''}"
    (comment['body'] || '').each_line { |line| puts "    #{line.chomp}" }
    puts
  end

  def cmd_get(args)
    usage = 'Usage: linear get ABC-NNN [--full] [--json]'
    json_mode = false
    full = false
    rest = parse_options(args, usage) do |o|
      o.on('--full') { full = true }
      o.on('--json') { json_mode = true }
    end
    identifier = take_positionals!(rest, 1, usage).first

    fields = ISSUE_CORE_FIELDS.dup
    fields << ISSUE_COMMENT_FIELDS if full

    client = Client.new
    team_key, number = parse_identifier!(identifier)

    res = client.query(<<~GQL, { teamKey: team_key, number: number })
      query($teamKey: String!, $number: Float!) {
        issues(filter: { number: { eq: $number }, team: { key: { eq: $teamKey } } }) {
          nodes { #{fields} }
        }
      }
    GQL

    if json_mode
      puts JSON.pretty_generate(res)
      return
    end

    issue = res.dig('data', 'issues', 'nodes', 0)
    raise Error, "linear: issue #{identifier} not found" unless issue
    print_issue(issue, include_comments: full)
  end

  def cmd_comments(args)
    usage = 'Usage: linear comments ABC-NNN [--json]'
    json_mode = false
    rest = parse_options(args, usage) do |o|
      o.on('--json') { json_mode = true }
    end
    identifier = take_positionals!(rest, 1, usage).first

    client = Client.new
    team_key, number = parse_identifier!(identifier)

    res = client.query(<<~GQL, { teamKey: team_key, number: number })
      query($teamKey: String!, $number: Float!) {
        issues(filter: { number: { eq: $number }, team: { key: { eq: $teamKey } } }) {
          nodes {
            identifier
            #{ISSUE_COMMENT_FIELDS}
          }
        }
      }
    GQL

    if json_mode
      puts JSON.pretty_generate(res)
      return
    end

    issue = res.dig('data', 'issues', 'nodes', 0)
    raise Error, "linear: issue #{identifier} not found" unless issue
    comments = issue.dig('comments', 'nodes') || []
    puts "Comments on #{issue['identifier']} (#{comments.size}):"
    comments.each { |c| print_comment(c) }
  end

  def cmd_search(args)
    usage = 'Usage: linear search "phrase" [--team KEY] [--limit N] [--json]'
    json_mode = false
    team_key = nil
    limit_str = nil
    rest = parse_options(args, usage) do |o|
      value_option(o, '--team KEY') { |v| team_key = v }
      value_option(o, '--limit N') { |v| limit_str = v }
      o.on('--json') { json_mode = true }
    end
    limit = limit_str ? parse_limit(limit_str) : 25
    term = take_positionals!(rest, 1, usage).first
    raise Error, usage if term.empty?

    filter = {
      or: [
        { title: { containsIgnoreCase: term } },
        { description: { containsIgnoreCase: term } }
      ]
    }
    filter[:team] = { key: { eq: team_key } } if team_key

    client = Client.new
    res = client.query(<<~GQL, { filter: filter, first: limit })
      query($filter: IssueFilter!, $first: Int!) {
        issues(filter: $filter, first: $first, orderBy: updatedAt) {
          nodes { identifier title state { name } updatedAt }
        }
      }
    GQL

    if json_mode
      puts JSON.pretty_generate(res)
      return
    end

    nodes = res.dig('data', 'issues', 'nodes') || []
    if nodes.empty?
      puts '(no matches)'
      return
    end
    nodes.each do |n|
      date = (n['updatedAt'] || '')[0, 10]
      puts "#{n['identifier']} [#{n.dig('state', 'name')}] #{n['title']}  (#{date})"
    end
  end

  def cmd_create(args)
    usage = 'Usage: linear create --team KEY --title TITLE --priority LEVEL (--project NAME | --no-project) ' \
            '[--description TEXT | --description-file PATH] [--state NAME] [--parent ABC-NNN] ' \
            '[--assignee EMAIL|me] [--json]'
    team_key = nil
    project_name = nil
    title = nil
    description = nil
    description_file = nil
    no_project = false
    state_name = nil
    parent_id = nil
    assignee = nil
    priority = nil
    json_mode = false

    rest = parse_options(args, usage) do |o|
      value_option(o, '--team KEY') { |v| team_key = v }
      value_option(o, '--priority LEVEL', 'REQUIRED: urgent|high|medium|low, or an explicit none (or 0-4)') { |v| priority = v }
      value_option(o, '--project NAME') { |v| project_name = v }
      value_option(o, '--title TITLE') { |v| title = v }
      value_option(o, '--description TEXT') { |v| description = v }
      value_option(o, '--description-file PATH') { |v| description_file = v }
      value_option(o, '--state NAME', 'Workflow state (default: Todo; never Triage/Backlog)') { |v| state_name = v }
      value_option(o, '--parent ABC-NNN', 'Make the new issue a sub-issue of this parent') { |v| parent_id = v }
      value_option(o, '--assignee EMAIL|me',
                   'Assign the issue (required when creating in a started state like In Progress)') { |v| assignee = v }
      o.on('--no-project') { no_project = true }
      o.on('--json') { json_mode = true }
    end
    reject_positionals!(rest)

    raise Error, usage if team_key.nil? || title.nil?
    if priority.nil?
      raise Error, "linear: --priority is required on create (urgent|high|medium|low, or an explicit none).\n" \
                   "Guidelines: urgent = money/data actively wrong in prod, drop current work; " \
                   "high = users can hit it today or it gates scheduled work, this cycle; " \
                   "medium = default for scheduled improvements (refactors, epic phases, bugs with a workaround); " \
                   "low = non-compounding cleanups; none = deliberately parked (spike awaiting a decision).\n" \
                   "#{usage}"
    end
    reject_conflicting_sources!('--project' => !project_name.nil?, '--no-project' => no_project)
    unless project_name || no_project
      raise Error, "linear: --project is required (or pass --no-project to override).\n#{usage}"
    end

    reject_conflicting_sources!('--description' => !description.nil?,
                                '--description-file' => !description_file.nil?)
    description = read_file_option!(description_file, '--description-file') if description_file

    client = Client.new

    team_res = client.query(<<~GQL, { teamKey: team_key })
      query($teamKey: String!) {
        teams(filter: { key: { eq: $teamKey } }) { nodes { id key name } }
      }
    GQL
    team = team_res.dig('data', 'teams', 'nodes', 0)
    raise Error, "linear: team #{team_key} not found" unless team

    # New issues default to Todo, never the team's default Triage (or Backlog).
    # Pass --state "In Progress" when the issue is already being worked.
    desired_state = state_name || 'Todo'
    state_res = client.query(<<~GQL, { teamId: team['id'], name: desired_state })
      query($teamId: ID!, $name: String!) {
        workflowStates(filter: { team: { id: { eq: $teamId } }, name: { eq: $name } }) {
          nodes { id name type }
        }
      }
    GQL
    state = state_res.dig('data', 'workflowStates', 'nodes', 0)
    raise Error, "linear: state #{desired_state.inspect} not found on team #{team_key}" unless state

    # Creating directly in a started state (e.g. In Progress) requires an assignee.
    if state['type'] == STARTED_STATE_TYPE && assignee.nil?
      raise Error, "linear: creating in #{desired_state.inspect} (a started state) requires an assignee; " \
                   'pass --assignee EMAIL|me'
    end
    assignee_id = assignee ? client.resolve_user_id(assignee) : nil

    project_id = client.resolve_project_id(team['id'], project_name) if project_name

    input = { teamId: team['id'], title: title, stateId: state['id'] }
    input[:description] = description if description
    input[:projectId] = project_id if project_id
    input[:parentId] = client.resolve_issue(parent_id)['id'] if parent_id
    input[:assigneeId] = assignee_id if assignee_id
    input[:priority] = resolve_priority(priority) if priority

    res = client.query(<<~GQL, { input: input })
      mutation($input: IssueCreateInput!) {
        issueCreate(input: $input) {
          success
          issue { identifier title url state { name } project { name } parent { identifier } assignee { name } priorityLabel }
        }
      }
    GQL

    if json_mode
      puts JSON.pretty_generate(res)
      return
    end

    issue = res.dig('data', 'issueCreate', 'issue')
    raise Error, "linear: create failed: #{res.inspect}" unless issue
    puts "Created #{issue['identifier']}: #{issue['title']}"
    puts "State: #{issue.dig('state', 'name')} | Project: #{issue.dig('project', 'name') || '-'}"
    puts "Assignee: #{issue.dig('assignee', 'name') || '-'} | Priority: #{issue['priorityLabel'] || '-'}"
    puts "Parent: #{issue.dig('parent', 'identifier')}" if issue['parent']
    puts issue['url']
  end

  PRIORITY_NAMES = { 'none' => 0, 'urgent' => 1, 'high' => 2, 'medium' => 3, 'low' => 4 }.freeze

  def resolve_priority(value)
    key = value.to_s.strip.downcase
    return Integer(key) if key.match?(/\A[0-4]\z/)

    PRIORITY_NAMES[key] || raise(Error, "linear: invalid priority #{value.inspect}; use none|urgent|high|medium|low or 0-4")
  end

  def cmd_update(args)
    usage = 'Usage: linear update ABC-NNN [--state NAME] [--title TITLE] ' \
            '[--description TEXT | --description-file PATH] [--project NAME] [--parent ABC-NNN] ' \
            '[--assignee EMAIL|me] [--priority none|urgent|high|medium|low] [--json]'
    state_name = nil
    title = nil
    description = nil
    description_file = nil
    priority = nil
    project_name = nil
    parent_id = nil
    assignee = nil
    json_mode = false

    rest = parse_options(args, usage) do |o|
      value_option(o, '--priority LEVEL', 'Set priority (none|urgent|high|medium|low or 0-4)') { |v| priority = v }
      value_option(o, '--state NAME') { |v| state_name = v }
      value_option(o, '--title TITLE') { |v| title = v }
      value_option(o, '--description TEXT') { |v| description = v }
      value_option(o, '--description-file PATH') { |v| description_file = v }
      value_option(o, '--project NAME', 'Move the issue to this project') { |v| project_name = v }
      value_option(o, '--parent ABC-NNN', 'Reparent the issue under this parent') { |v| parent_id = v }
      value_option(o, '--assignee EMAIL|me',
                   'Assign the issue (required when moving to a started state like In Progress)') { |v| assignee = v }
      o.on('--json') { json_mode = true }
    end
    identifier = take_positionals!(rest, 1, usage).first

    reject_conflicting_sources!('--description' => !description.nil?,
                                '--description-file' => !description_file.nil?)
    description = read_file_option!(description_file, '--description-file') if description_file

    client = Client.new
    issue = client.resolve_issue(identifier, fields: 'id identifier team { id } assignee { id name }')

    input = {}
    input[:assigneeId] = client.resolve_user_id(assignee) if assignee
    if state_name
      state_res = client.query(<<~GQL, { teamId: issue.dig('team', 'id'), name: state_name })
        query($teamId: ID!, $name: String!) {
          workflowStates(filter: { team: { id: { eq: $teamId } }, name: { eq: $name } }) {
            nodes { id name type }
          }
        }
      GQL
      state = state_res.dig('data', 'workflowStates', 'nodes', 0)
      unless state
        raise Error, "linear: state #{state_name.inspect} not found on team #{identifier.split('-').first&.upcase}"
      end
      input[:stateId] = state['id']

      # Moving into a started state (e.g. In Progress) requires an assignee:
      # either one passed this call, or one already on the issue.
      if state['type'] == STARTED_STATE_TYPE && !input.key?(:assigneeId) && issue.dig('assignee', 'id').nil?
        raise Error, "linear: moving #{identifier} to #{state_name.inspect} (a started state) requires an assignee; " \
                     'pass --assignee EMAIL|me'
      end
    end
    input[:priority] = resolve_priority(priority) if priority
    input[:title] = title if title
    input[:description] = description if description
    input[:projectId] = client.resolve_project_id(issue.dig('team', 'id'), project_name) if project_name
    input[:parentId] = client.resolve_issue(parent_id)['id'] if parent_id
    if input.empty?
      raise Error, 'linear: nothing to update; pass --state, --title, --description, --project, --parent, --assignee, or --priority'
    end

    res = client.query(<<~GQL, { id: issue['id'], input: input })
      mutation($id: String!, $input: IssueUpdateInput!) {
        issueUpdate(id: $id, input: $input) {
          success
          issue { identifier title url state { name } project { name } parent { identifier } assignee { name } priorityLabel }
        }
      }
    GQL

    if json_mode
      puts JSON.pretty_generate(res)
      return
    end

    updated = res.dig('data', 'issueUpdate', 'issue')
    raise Error, "linear: update failed: #{res.inspect}" unless updated
    puts "Updated #{updated['identifier']}: [#{updated.dig('state', 'name')}] #{updated['title']}"
    puts "Project: #{updated.dig('project', 'name') || '-'} | Parent: #{updated.dig('parent', 'identifier') || '-'}"
    puts "Assignee: #{updated.dig('assignee', 'name') || '-'} | Priority: #{updated['priorityLabel'] || '-'}"
    puts updated['url']
  end

  def cmd_comment(args)
    usage = 'Usage: linear comment ABC-NNN ("message" | --body TEXT | --body-file PATH)'
    json_mode = false
    body_file = nil
    body_opt = nil
    # The one subcommand that keeps its trailing positionals: they are
    # the message. A dash-leading word in that message needs a '--'
    # terminator, or --body/--body-file.
    rest = parse_options(args, usage, hint: '(comment takes a positional message, ' \
                                            '--body TEXT, or --body-file PATH)') do |o|
      value_option(o, '--body TEXT') { |v| body_opt = v }
      value_option(o, '--body-file PATH') { |v| body_file = v }
      o.on('--json') { json_mode = true }
    end
    identifier = rest.shift

    reject_conflicting_sources!('a positional message' => !rest.empty?,
                                '--body' => !body_opt.nil?,
                                '--body-file' => !body_file.nil?)
    body =
      if body_file
        read_file_option!(body_file, '--body-file')
      elsif body_opt
        body_opt
      else
        rest.join(' ')
      end
    raise Error, usage if identifier.nil? || body.strip.empty?

    client = Client.new
    issue = client.resolve_issue(identifier)

    res = client.query(<<~GQL, { input: { issueId: issue['id'], body: body } })
      mutation($input: CommentCreateInput!) {
        commentCreate(input: $input) {
          success
          comment { id url }
        }
      }
    GQL

    if json_mode
      puts JSON.pretty_generate(res)
      return
    end

    comment = res.dig('data', 'commentCreate', 'comment')
    raise Error, "linear: comment failed: #{res.inspect}" unless comment
    puts "Posted comment on #{identifier}: #{comment['url']}"
  end

  def cmd_comment_delete(args)
    usage = 'Usage: linear comment-delete COMMENT_ID (see "linear comments ABC-NNN")'
    json_mode = false
    rest = parse_options(args, usage) do |o|
      o.on('--json') { json_mode = true }
    end
    comment_id = take_positionals!(rest, 1, usage).first
    raise Error, usage if comment_id.empty?

    client = Client.new
    res = client.query(<<~GQL, { id: comment_id })
      mutation($id: String!) {
        commentDelete(id: $id) { success }
      }
    GQL

    if json_mode
      puts JSON.pretty_generate(res)
      return
    end

    raise Error, "linear: comment delete failed: #{res.inspect}" unless res.dig('data', 'commentDelete', 'success')
    puts "Deleted comment #{comment_id}"
  end

  def cmd_relate(args)
    usage = 'Usage: linear relate ABC-AAA ABC-BBB [--type related|blocks|duplicate] [--json]'
    type = 'related'
    json_mode = false
    rest = parse_options(args, usage) do |o|
      value_option(o, '--type TYPE') { |v| type = v }
      o.on('--json') { json_mode = true }
    end
    source, target = take_positionals!(rest, 2, usage)

    client = Client.new
    source_issue = client.resolve_issue(source, fields: 'id identifier')
    target_issue = client.resolve_issue(target, fields: 'id identifier')

    res = client.query(<<~GQL, { input: { issueId: source_issue['id'], relatedIssueId: target_issue['id'], type: type } })
      mutation($input: IssueRelationCreateInput!) {
        issueRelationCreate(input: $input) {
          success
          issueRelation { type issue { identifier } relatedIssue { identifier } }
        }
      }
    GQL

    if json_mode
      puts JSON.pretty_generate(res)
      return
    end

    rel = res.dig('data', 'issueRelationCreate', 'issueRelation')
    raise Error, "linear: relate failed: #{res.inspect}" unless rel
    puts "Related #{rel.dig('issue', 'identifier')} <-> #{rel.dig('relatedIssue', 'identifier')} (#{rel['type']})"
  end

  def cmd_project_create(args)
    usage = 'Usage: linear project-create --team KEY --name NAME ' \
            '[--description TEXT] [--content TEXT | --content-file PATH] [--json]'
    team_key = nil
    name = nil
    description = nil
    content = nil
    content_file = nil
    json_mode = false
    rest = parse_options(args, usage) do |o|
      value_option(o, '--team KEY') { |v| team_key = v }
      value_option(o, '--name NAME') { |v| name = v }
      value_option(o, '--description TEXT', 'Short one-line project summary') { |v| description = v }
      value_option(o, '--content TEXT', 'Project body (markdown)') { |v| content = v }
      value_option(o, '--content-file PATH', 'Read project body (markdown) from a file') { |v| content_file = v }
      o.on('--json') { json_mode = true }
    end
    reject_positionals!(rest)
    raise Error, usage if team_key.nil? || name.nil?
    reject_conflicting_sources!('--content' => !content.nil?, '--content-file' => !content_file.nil?)
    content = read_file_option!(content_file, '--content-file') if content_file

    client = Client.new
    team_res = client.query(<<~GQL, { teamKey: team_key })
      query($teamKey: String!) {
        teams(filter: { key: { eq: $teamKey } }) { nodes { id key name } }
      }
    GQL
    team = team_res.dig('data', 'teams', 'nodes', 0)
    raise Error, "linear: team #{team_key} not found" unless team

    input = { name: name, teamIds: [team['id']] }
    input[:description] = description if description
    input[:content] = content if content

    res = client.query(<<~GQL, { input: input })
      mutation($input: ProjectCreateInput!) {
        projectCreate(input: $input) {
          success
          project { id name url }
        }
      }
    GQL

    if json_mode
      puts JSON.pretty_generate(res)
      return
    end
    project = res.dig('data', 'projectCreate', 'project')
    raise Error, "linear: project create failed: #{res.inspect}" unless project
    puts "Created project: #{project['name']}"
    puts "Id: #{project['id']}"
    puts project['url']
  end

  def cmd_project_update(args)
    usage = 'Usage: linear project-update --id PROJECT_ID ' \
            '[--name NAME] [--description TEXT] [--content TEXT | --content-file PATH] [--json]'
    id = nil
    name = nil
    description = nil
    content = nil
    content_file = nil
    json_mode = false
    rest = parse_options(args, usage) do |o|
      value_option(o, '--id ID') { |v| id = v }
      value_option(o, '--name NAME') { |v| name = v }
      value_option(o, '--description TEXT', 'Short one-line project summary') { |v| description = v }
      value_option(o, '--content TEXT', 'Project body (markdown)') { |v| content = v }
      value_option(o, '--content-file PATH', 'Read project body (markdown) from a file') { |v| content_file = v }
      o.on('--json') { json_mode = true }
    end
    reject_positionals!(rest)
    raise Error, usage if id.nil?
    reject_conflicting_sources!('--content' => !content.nil?, '--content-file' => !content_file.nil?)
    content = read_file_option!(content_file, '--content-file') if content_file

    input = {}
    input[:name] = name if name
    input[:description] = description if description
    input[:content] = content if content
    raise Error, "linear: nothing to update; pass --name, --description, or --content" if input.empty?

    client = Client.new
    res = client.query(<<~GQL, { id: id, input: input })
      mutation($id: String!, $input: ProjectUpdateInput!) {
        projectUpdate(id: $id, input: $input) {
          success
          project { id name url }
        }
      }
    GQL
    if json_mode
      puts JSON.pretty_generate(res)
      return
    end
    project = res.dig('data', 'projectUpdate', 'project')
    raise Error, "linear: project update failed: #{res.inspect}" unless project
    puts "Updated project: #{project['name']}"
    puts project['url']
  end

  def cmd_project_list(args)
    usage = 'Usage: linear project-list --team KEY [--json] (or set LINEAR_TEAM_KEY)'
    json_mode = false
    team_opt = nil
    rest = parse_options(args, usage) do |o|
      value_option(o, '--team KEY') { |v| team_opt = v }
      o.on('--json') { json_mode = true }
    end
    reject_positionals!(rest)
    team_key = team_opt || ENV['LINEAR_TEAM_KEY']
    raise Error, usage if team_key.nil? || team_key.empty?
    client = Client.new
    res = client.query(<<~GQL, { teamKey: team_key })
      query($teamKey: String!) {
        teams(filter: { key: { eq: $teamKey } }) {
          nodes { id projects(first: 100) { nodes { id name state } } }
        }
      }
    GQL
    team = res.dig('data', 'teams', 'nodes', 0)
    raise Error, "linear: team #{team_key} not found" unless team
    if json_mode
      puts JSON.pretty_generate(res)
      return
    end
    projects = team.dig('projects', 'nodes') || []
    projects.sort_by { |p| p['name'].to_s.downcase }.each do |p|
      puts "#{p['name']} [#{p['state']}] (#{p['id']})"
    end
  end

  USAGE = <<~TXT
      linear -- semantic CLI for Linear (uses LINEAR_API_TOKEN)

      Read:
        linear get ABC-NNN [--full] [--json]
            Show title, state, description, team, project, parent, children.
            --full also includes the comment thread.

        linear comments ABC-NNN [--json]
            Show just the comment thread.

        linear search "phrase" [--team KEY] [--limit N] [--json]
            Case-insensitive substring search across title and description.

        linear list --team KEY (--project NAME | --since YYYY-MM-DD)
                    [--all] [--limit N] [--json]
            List a team's issues, filtered to a project and/or a created-since
            date. Excludes completed/canceled unless --all -- pass --all when
            mining history, since shipped issues are the interesting ones.
            Paginates past the API's 250-per-page cap up to --limit (default
            100). With --since, results sort and display by created date.

      Write:
        linear create --team KEY --title TITLE --priority LEVEL
                      (--project NAME | --no-project)
                      [--description TEXT | --description-file PATH] [--state NAME]
                      [--parent ABC-NNN] [--assignee EMAIL|me] [--json]
            Create a new issue. --project is required; pass --no-project to override.
            --priority is required: urgent = money/data actively wrong in prod;
            high = users can hit it today or it gates scheduled work; medium =
            default for scheduled improvements; low = non-compounding cleanups;
            none = deliberately parked (explicit only, never an accidental default).
            Defaults to the Todo state (never Triage/Backlog); pass
            --state "In Progress" when the issue is already being worked.
            --parent makes the new issue a sub-issue of the given parent.
            --assignee takes an email, a name substring, or the literal "me"
            (the token's own user). Required when the state is a started state.

        linear update ABC-NNN [--state NAME] [--title TITLE]
                      [--description TEXT | --description-file PATH]
                      [--project NAME] [--parent ABC-NNN] [--assignee EMAIL|me]
                      [--priority none|urgent|high|medium|low] [--json]
            Update state, title, description, project, parent, assignee, or priority.
            --project moves the issue; --parent reparents it as a sub-issue.
            Moving to a started state (e.g. In Progress) requires an assignee:
            pass --assignee, or the issue must already have one.

        linear comment ABC-NNN ("message" | --body TEXT | --body-file PATH) [--json]
            Post a comment. Use --body-file for long/markdown bodies.

        linear comment-delete COMMENT_ID [--json]
            Delete a comment by id (ids are shown by "linear comments ABC-NNN").

        linear relate ABC-AAA ABC-BBB [--type related|blocks|duplicate] [--json]
            Link two issues (default: related).

        linear project-create --team KEY --name NAME [--description TEXT]
                      [--content TEXT | --content-file PATH] [--json]
            Create a project on a team. --description is the one-line summary;
            --content is the full markdown body. Move issues into it afterward
            with `linear update ABC-NNN --project NAME`.

        linear project-update --id PROJECT_ID [--name NAME] [--description TEXT]
                      [--content TEXT | --content-file PATH] [--json]
            Update a project's name, one-line summary, or markdown body.

        linear project-list --team KEY [--json]
            List a team's projects with their ids and state.

      Dash-leading values:
        A value that begins with '-' is otherwise read as a flag and
        rejected. Put '--' before a dash-leading search term or comment
        message so the rest of the line is taken literally:
            linear search -- -oauth
            linear comment ABC-NNN -- -1 broke the build
        '--' guards positionals only -- it cannot rescue a dash-leading
        OPTION value. --description, project --content, and the comment
        body each have a --*-file variant for text that begins with a
        dash. The other free-text options (--title, --name, --state,
        --project) have no such variant, so a value beginning with a
        dash cannot be passed to them at all. Every remaining option
        takes a key, id, enum word, email, or date that never begins
        with a dash.
  TXT

  def cmd_list(args)
    usage = 'Usage: linear list --team KEY (--project NAME | --since YYYY-MM-DD) [--all] [--limit N] [--json] ' \
            '(--team may be omitted when LINEAR_TEAM_KEY is set)'
    json_mode = false
    all = false
    team_opt = nil
    project_name = nil
    since = nil
    limit_str = nil
    rest = parse_options(args, usage) do |o|
      value_option(o, '--team KEY') { |v| team_opt = v }
      value_option(o, '--project NAME') { |v| project_name = v }
      value_option(o, '--since YYYY-MM-DD') { |v| since = v }
      value_option(o, '--limit N') { |v| limit_str = v }
      o.on('--all') { all = true }
      o.on('--json') { json_mode = true }
    end
    reject_positionals!(rest)
    team_key = team_opt || ENV['LINEAR_TEAM_KEY']
    limit = limit_str ? parse_limit(limit_str) : 100
    raise Error, usage if team_key.nil? || team_key.empty? || (project_name.nil? && since.nil?)
    if since && since !~ /\A\d{4}-\d{2}-\d{2}\z/
      raise Error, "linear: --since must be YYYY-MM-DD, got #{since.inspect}"
    end

    filter = { team: { key: { eq: team_key } } }
    filter[:project] = { name: { containsIgnoreCase: project_name } } if project_name
    filter[:createdAt] = { gte: since } if since
    filter[:state] = { type: { nin: %w[completed canceled] } } unless all

    order_by = since ? 'createdAt' : 'updatedAt'
    client = Client.new
    nodes = []
    cursor = nil
    loop do
      page_size = [limit - nodes.size, 250].min
      break if page_size <= 0

      res = client.query(<<~GQL, { filter: filter, first: page_size, after: cursor })
        query($filter: IssueFilter!, $first: Int!, $after: String) {
          issues(filter: $filter, first: $first, after: $after, orderBy: #{order_by}) {
            nodes { identifier title priority state { name } project { name } createdAt updatedAt }
            pageInfo { hasNextPage endCursor }
          }
        }
      GQL
      nodes.concat(res.dig('data', 'issues', 'nodes') || [])
      page_info = res.dig('data', 'issues', 'pageInfo') || {}
      break unless page_info['hasNextPage']

      cursor = page_info['endCursor']
    end

    if json_mode
      puts JSON.pretty_generate({ 'nodes' => nodes })
      return
    end

    if nodes.empty?
      puts '(no matches)'
      return
    end
    prio = { 0 => '-', 1 => 'Urgent', 2 => 'High', 3 => 'Med', 4 => 'Low' }
    nodes.each do |n|
      date = ((since ? n['createdAt'] : n['updatedAt']) || '')[0, 10]
      project = project_name ? '' : "  {#{n.dig('project', 'name')}}"
      puts "#{n['identifier']} [#{n.dig('state', 'name')}] (#{prio[n['priority']]}) #{n['title']}  (#{date})#{project}"
    end
  end

  class CLI
    # The subcommand table, one entry per cmd_* handler. Kept as a
    # constant rather than an inline case so tests can iterate it and
    # assert every subcommand carries the shared guards -- a new
    # subcommand then cannot silently skip them.
    COMMANDS = {
      'get' => :cmd_get,
      'comments' => :cmd_comments,
      'search' => :cmd_search,
      'list' => :cmd_list,
      'create' => :cmd_create,
      'update' => :cmd_update,
      'comment' => :cmd_comment,
      'comment-delete' => :cmd_comment_delete,
      'relate' => :cmd_relate,
      'project-create' => :cmd_project_create,
      'project-update' => :cmd_project_update,
      'project-list' => :cmd_project_list
    }.freeze

    def self.run(argv)
      new.run(argv)
    end

    def run(argv)
      command = argv.shift
      if (handler = COMMANDS[command])
        Linear.public_send(handler, argv)
      elsif [nil, 'help', '--help', '-h'].include?(command)
        puts USAGE
      else
        warn "linear: unknown subcommand #{command.inspect}"
        puts USAGE
        exit 1
      end
    rescue Error => e
      abort e.message
    end
  end
end

Linear::CLI.run(ARGV) if $PROGRAM_NAME == __FILE__
