#!/usr/bin/env ruby
# frozen_string_literal: true

# gh-issue-sync -- GitHub issue-body read-modify-write helper.
#
# `gh issue edit --body-file` replaces the entire issue body, so every
# body edit is a fetch-modify-write cycle with sharp edges: stale
# fetches clobber concurrent edits, jq-piped fetches grow the body by a
# trailing newline per cycle, web-UI edits switch the body to CRLF, and
# a hand-rolled checklist sync can leave the public surface stale. This
# tool wraps those mechanics. Auth and transport are delegated to `gh`.
#
# Stdlib-only (no gems). Run with no arguments for usage.
#
# The checklist section it owns is delimited by paired HTML-comment
# markers (invisible on GitHub), wrapping the heading so regeneration
# owns it too:
#
#   <!-- gh-issue-sync: <slug> -->
#   ## To-dos
#   - [x] **1.** ...
#   <!-- /gh-issue-sync: <slug> -->
#
# The slug is the --plan file's basename, so several plans can share
# one issue, each owning its own section. The section is a projection
# of the plan file: sync regenerates it wholesale, and anything on the
# GitHub side the plan does not carry -- a ticked box, an edited item
# text, a hand-added item -- is surfaced as a warning (the plan wins),
# never silently kept or silently lost.
#
# Known limitation: `## To-dos` headings inside fenced code blocks are
# correctly ignored, but the sync markers themselves are assumed never
# to appear inside a fence.

require 'json'
require 'open3'
require 'optparse'
require 'tempfile'

module GhIssueSync
  Error = Class.new(StandardError)

  # GitHub rejects issue bodies past 256 KiB -- measured empirically at
  # exactly 262144 bytes with ASCII bodies (the widely-cited 65536
  # figure is the comment limit, not the body's). If GitHub's
  # enforcement unit turns out to be characters, this byte guard is the
  # conservative side for multibyte bodies.
  MAX_BODY_BYTES = 262_144

  TODO_LINE = /\A- \[(x| )\] \*\*(\d+)\.\*\* (.+)\z/
  CHECKBOX_START = /\A\s*- \[/
  TODOS_HEADING = /\A## To-dos\b/
  OPEN_MARKER = /\A<!-- gh-issue-sync: \S+ -->/
  CLOSE_MARKER = %r{\A<!-- /gh-issue-sync: \S+ -->}

  # Text contract: the public module functions accept CRLF or LF and
  # normalize once on entry; the private line-scanning helpers assume
  # LF-only input.

  module_function

  def normalize(text)
    text.gsub("\r\n", "\n")
  end

  # Parses the plan file's "## To-dos" section into
  # [{number:, checked:, text:}, ...]. Indented continuation lines fold
  # into the preceding item's text. Only top-level items are legal:
  # any checkbox line in the section that misses the strict
  # "- [ ] **N.** text" shape -- including an indented/nested checkbox
  # -- raises rather than being silently skipped or promoted, because a
  # skipped line would go permanently stale on the issue and a promoted
  # nested item would break the stable-numbering contract. Checkboxes
  # outside the section (acceptance criteria, examples) are none of our
  # business.
  def parse_plan_todos(plan_text)
    lines = normalize(plan_text).lines
    bounds = heading_bounds(lines)
    raise Error, "plan has no '## To-dos' section" unless bounds

    items = []
    lines[(bounds[0] + 1)...bounds[1]].each do |raw|
      line = raw.chomp
      if (m = TODO_LINE.match(line))
        items << { number: m[2].to_i, checked: m[1] == 'x', text: m[3] }
      elsif CHECKBOX_START.match?(line)
        raise Error, "malformed to-do line (expected top-level '- [ ] **N.** text'): #{line.strip}"
      elsif line.start_with?('  ') && !line.strip.empty? && items.any?
        items.last[:text] = "#{items.last[:text]} #{line.strip}"
      end
    end
    items
  end

  def render_section(items, slug:, heading_suffix: nil)
    heading = heading_suffix ? "## To-dos (#{heading_suffix})" : '## To-dos'
    lines = ["<!-- gh-issue-sync: #{slug} -->", heading]
    items.each do |item|
      lines << "- [#{item[:checked] ? 'x' : ' '}] **#{item[:number]}.** #{item[:text]}"
    end
    lines << "<!-- /gh-issue-sync: #{slug} -->"
    lines.join("\n")
  end

  # The one-call sync entry point: regenerates this slug's section from
  # the plan's items and returns [new_body, warnings], so the
  # never-silently-overwrite guarantee travels with the overwrite
  # instead of relying on every caller to remember the divergence
  # check.
  def sync_section(body, items, slug:, heading_suffix: nil)
    body = normalize(body)
    divs = divergences(section_items(body, slug: slug), items)
    warnings =
      if divs.empty?
        []
      else
        ["#{divs.join('; ')} -- the plan file wins; absorb real GitHub-side changes into the plan, then re-sync"]
      end
    rendered = render_section(items, slug: slug, heading_suffix: heading_suffix)
    [upsert_section(body, rendered, slug: slug), warnings]
  end

  # Regenerates this slug's section in place; creates it (at the end of
  # the body) when absent. A marker-less "## To-dos" heading left by a
  # pre-helper flow is adopted -- replaced up to the next "##" heading
  # -- rather than duplicated; headings inside another slug's marker
  # pair or inside a fenced code block are never adoption targets.
  def upsert_section(body, rendered, slug:)
    body = normalize(body)
    pattern = section_pattern(slug)
    if body.match?(pattern)
      body.sub(pattern) { rendered }
    elsif (adopted = adopt_heading(body, rendered))
      adopted
    else
      append_body(body, rendered)
    end
  end

  # Reads this slug's section back out of a body, for divergence checks.
  def section_items(body, slug:)
    match = section_pattern(slug).match(normalize(body))
    return [] unless match

    match[0].each_line.filter_map do |line|
      m = TODO_LINE.match(line.chomp)
      m && { number: m[2].to_i, checked: m[1] == 'x', text: m[3] }
    end
  end

  # Anything on the GitHub side the plan does not carry is a human
  # signal the plan file never absorbed: a tick, an edited item text,
  # or a hand-added item. The plan is the source of truth, so the sync
  # overwrites -- but never silently.
  def divergences(body_items, plan_items)
    plan_by_number = plan_items.to_h { |item| [item[:number], item] }
    body_items.filter_map do |body_item|
      plan_item = plan_by_number[body_item[:number]]
      if plan_item.nil?
        "item #{body_item[:number]} exists only on GitHub"
      elsif body_item[:checked] && !plan_item[:checked]
        "item #{body_item[:number]} is ticked on GitHub but unchecked in the plan"
      elsif body_item[:text] != plan_item[:text]
        "item #{body_item[:number]}'s text differs between GitHub and the plan"
      end
    end
  end

  # Joins with exactly one blank line. Leading blank lines and trailing
  # whitespace are trimmed from the addition, but never the first
  # line's indentation -- an appended file may open with an indented
  # code block.
  def append_body(body, addition)
    body = normalize(body).rstrip
    addition = normalize(addition).sub(/\A(?:[ \t]*\n)+/, '').rstrip
    return "#{addition}\n" if body.empty?

    "#{body}\n\n#{addition}\n"
  end

  # The finish-phase reconcile must leave the public checklist in a
  # final state, and a bare unchecked box is not one: every item is
  # either done or explicitly deferred by the time an issue wraps up.
  def assert_reconcilable!(items)
    unchecked = items.reject { |item| item[:checked] }
    return items if unchecked.empty?

    listing = unchecked.map { |item| "  #{item[:number]}. #{item[:text]}" }.join("\n")
    raise Error,
          "reconcile refused: the plan still has bare unchecked to-dos -- " \
          "finish them or mark them deferred first:\n#{listing}"
  end

  def check_length!(body)
    return body if body.bytesize <= MAX_BODY_BYTES

    raise Error,
          "new body would be #{body.bytesize} bytes; GitHub's issue-body limit is #{MAX_BODY_BYTES} bytes (256 KiB)"
  end

  def section_pattern(slug)
    open_marker = Regexp.escape("<!-- gh-issue-sync: #{slug} -->")
    close_marker = Regexp.escape("<!-- /gh-issue-sync: #{slug} -->")
    /#{open_marker}.*?#{close_marker}/m
  end

  # The lines [start, stop) of the first "## To-dos" section: heading
  # at start, body up to (not including) the next "##" heading or end
  # of input. Skips headings inside fenced code blocks and inside any
  # line ranges passed as exclude (marker-wrapped sections during
  # adoption). Returns nil when no eligible heading exists.
  def heading_bounds(lines, exclude: [])
    in_fence = false
    start = nil
    lines.each_with_index do |raw, i|
      line = raw.chomp
      if line.lstrip.start_with?('```')
        in_fence = !in_fence
        next
      end
      next if in_fence

      if start.nil?
        start = i if TODOS_HEADING.match?(line) && exclude.none? { |range| range.cover?(i) }
      elsif line.start_with?('## ')
        return [start, i]
      end
    end
    start && [start, lines.length]
  end

  # Line-index ranges of every marker-delimited section in the body,
  # regardless of slug.
  def marked_line_ranges(lines)
    ranges = []
    open_index = nil
    lines.each_with_index do |raw, i|
      line = raw.chomp
      if open_index.nil? && OPEN_MARKER.match?(line)
        open_index = i
      elsif open_index && CLOSE_MARKER.match?(line)
        ranges << (open_index..i)
        open_index = nil
      end
    end
    ranges
  end

  def adopt_heading(body, rendered)
    lines = body.lines
    bounds = heading_bounds(lines, exclude: marked_line_ranges(lines))
    return nil unless bounds

    start, stop = bounds
    before = lines[0...start].join.rstrip
    after = lines[stop..].join.strip
    result = before.empty? ? '' : "#{before}\n\n"
    result += "#{rendered.rstrip}\n"
    result += "\n#{after}\n" unless after.empty?
    result
  end

  USAGE = <<~TXT
    gh-issue-sync -- GitHub issue-body read-modify-write helper (uses gh)

    gh-issue-sync append NNN --file <md> [--repo owner/name]
        Append the file's content to the issue body, separated by
        exactly one blank line. NOT idempotent: re-running appends
        again. For repeatable syncs use checklist/reconcile.

    gh-issue-sync checklist NNN --plan <plan.md> [--heading <slug>] [--repo owner/name]
        Regenerate the issue body's checklist section from the plan
        file's '## To-dos' items (strict top-level '- [ ] **N.** text'
        shape). The section is delimited by
        <!-- gh-issue-sync: <slug> --> markers (slug = the plan file's
        basename); it is created when absent, and a marker-less
        pre-helper '## To-dos' heading is adopted, not duplicated.
        --heading adds a visible '## To-dos (<slug>)' suffix for
        multi-plan issues. Idempotent. Anything on the GitHub side the
        plan lacks -- a tick, an edited item text, a hand-added item --
        is overwritten with a warning: the plan file is the source of
        truth, so absorb real GitHub-side changes into it and re-sync.

    gh-issue-sync reconcile NNN --plan <plan.md> [--heading <slug>] [--repo owner/name]
        The finish-phase sync: same regeneration, but refuses to run
        while the plan still has bare unchecked to-dos -- every item
        must be checked (done, or checked with a deferred-to note) so
        the public checklist never ends stale.

    The body is re-fetched immediately before every write (GitHub has
    no compare-and-swap). Fetches go through JSON.parse, never jq -r,
    so bodies round-trip byte-exact; CRLF from web-UI edits is
    normalized to LF.
  TXT

  class CLI
    def self.run(argv)
      new.run(argv)
    end

    def run(argv)
      command = argv.shift
      case command
      when 'append'    then append(argv)
      when 'checklist' then sync(argv, reconcile: false)
      when 'reconcile' then sync(argv, reconcile: true)
      when nil, 'help', '--help', '-h' then puts USAGE
      else
        warn "gh-issue-sync: unknown subcommand #{command.inspect}"
        warn USAGE
        exit 1
      end
    rescue Error => e
      abort "gh-issue-sync: #{e.message}"
    end

    private

    def append(argv)
      options = {}
      rest = parse_options(argv, 'append NNN --file <md> [--repo owner/name]') do |o|
        o.on('--file PATH', 'markdown file to append') { |v| options[:file] = v }
        o.on('--repo NAME', 'owner/name pass-through to gh') { |v| options[:repo] = v }
      end
      number = issue_number(rest)
      path = options[:file]
      raise Error, 'append requires --file <md>' unless path
      raise Error, "file not found: #{path}" unless File.exist?(path)

      addition = File.read(path)
      raise Error, "file is empty: #{path}" if addition.strip.empty?

      body = fetch_body(number, options[:repo])
      write_body(number, options[:repo], GhIssueSync.append_body(body, addition))
      puts "Appended #{path} to issue ##{number}"
    end

    def sync(argv, reconcile:)
      subcommand = reconcile ? 'reconcile' : 'checklist'
      options = {}
      rest = parse_options(argv, "#{subcommand} NNN --plan <plan.md> [--heading <slug>] [--repo owner/name]") do |o|
        o.on('--plan PATH', 'plan file whose To-dos drive the sync') { |v| options[:plan] = v }
        o.on('--heading SLUG', 'visible heading suffix for multi-plan issues') { |v| options[:heading] = v }
        o.on('--repo NAME', 'owner/name pass-through to gh') { |v| options[:repo] = v }
      end
      number = issue_number(rest)
      plan_path = options[:plan]
      raise Error, "#{subcommand} requires --plan <plan.md>" unless plan_path
      raise Error, "plan file not found: #{plan_path}" unless File.exist?(plan_path)

      items = GhIssueSync.parse_plan_todos(File.read(plan_path))
      GhIssueSync.assert_reconcilable!(items) if reconcile
      slug = File.basename(plan_path, '.md')

      body = fetch_body(number, options[:repo])
      new_body, warnings = GhIssueSync.sync_section(body, items, slug: slug, heading_suffix: options[:heading])
      warnings.each { |warning| warn "gh-issue-sync: warning: #{warning}" }
      write_body(number, options[:repo], new_body)

      done = items.count { |item| item[:checked] }
      puts "#{reconcile ? 'Reconciled' : 'Synced'} #{slug} on issue ##{number} (#{done} of #{items.length} checked)"
    end

    def parse_options(argv, banner)
      parser = OptionParser.new do |o|
        o.banner = "Usage: gh-issue-sync #{banner}"
        yield o
      end
      parser.parse(argv)
    rescue OptionParser::ParseError => e
      raise Error, e.message
    end

    def issue_number(rest)
      number = rest.first
      raise Error, 'missing issue number' unless number
      raise Error, "issue number must be digits, got #{number.inspect}" unless number.match?(/\A\d+\z/)

      number
    end

    def fetch_body(number, repo)
      output = gh(['issue', 'view', number, '--json', 'body'], repo)
      GhIssueSync.normalize(JSON.parse(output)['body'].to_s)
    end

    def write_body(number, repo, body)
      GhIssueSync.check_length!(body)
      Tempfile.create('gh-issue-sync-body') do |file|
        file.write(body)
        file.flush
        gh(['issue', 'edit', number, '--body-file', file.path], repo)
      end
    end

    def gh(args, repo)
      command = ['gh', *args]
      command += ['--repo', repo] if repo
      stdout, stderr, status = Open3.capture3(*command)
      raise Error, "gh #{args.first(2).join(' ')} failed: #{stderr.strip}" unless status.success?

      stdout
    rescue Errno::ENOENT
      raise Error, 'gh not found on PATH (install the GitHub CLI)'
    end
  end
end

GhIssueSync::CLI.run(ARGV) if $PROGRAM_NAME == __FILE__
