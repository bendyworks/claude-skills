#!/usr/bin/env ruby
# frozen_string_literal: true

# gh-issue-sync -- GitHub issue-body read-modify-write helper.
#
# `gh issue edit --body-file` replaces the entire issue body, so every
# body edit is a fetch-modify-write cycle with sharp edges: stale
# fetches clobber concurrent edits, jq-piped fetches grow the body by a
# trailing newline per cycle, web-UI edits switch the body to CRLF, and
# a hand-rolled checklist sync can leave the public surface stale. This
# tool wraps those mechanics. Auth and transport are delegated to `gh`.
#
# Stdlib-only (no gems). Run with no arguments for usage.
#
# The sections it owns are delimited by paired HTML-comment markers
# (invisible on GitHub), each keyed by a slug, and come in two kinds.
# Checklist sections wrap a heading and items regenerated from a plan
# file's To-dos (slug = the --plan file's basename minus .md):
#
#   <!-- gh-issue-sync: <slug> -->
#   ## To-dos
#   - [x] **1.** ...
#   <!-- /gh-issue-sync: <slug> -->
#
# Content sections wrap an arbitrary file's content verbatim (slug =
# the typed --slug). Both are projections of their source file:
# regeneration replaces them wholesale. For checklists, anything on
# the GitHub side the plan does not carry -- a ticked box, an edited
# item text, a hand-added item -- is surfaced as a warning (the plan
# wins), never silently kept or silently lost; for content sections
# the file simply wins, as the usage text says. The two kinds refuse
# to overwrite each other.
#
# Known limitations around fenced code blocks: `## To-dos` headings
# inside a fence are correctly ignored, but the sync markers themselves
# are assumed never to start a line inside one (the content-section
# guard refuses such content outright, keeping the assumption true), a
# fence INSIDE the plan's To-dos section may still trip the strict
# line parser, and only triple-backtick fences are recognized (not ~~~
# or longer runs).

require 'json'
require 'open3'
require 'optparse'
require 'tempfile'

module GhIssueSync
  Error = Class.new(StandardError)

  # GitHub rejects issue bodies past 256 KiB -- measured empirically at
  # exactly 262144 bytes with ASCII bodies (the widely-cited 65536
  # figure is the comment limit, not the body's). If GitHub's
  # enforcement unit turns out to be characters, this byte guard is the
  # conservative side for multibyte bodies.
  MAX_BODY_BYTES = 262_144

  TODO_LINE = /\A- \[(x| )\] \*\*(\d+)\.\*\* (.+)\z/
  # Checkbox-shaped only: a markdown link bullet ("- [text](url)") must
  # not read as a malformed checkbox.
  CHECKBOX_START = /\A\s*- \[[ xX]?\]/
  TODOS_HEADING = /\A## To-dos\b/
  OPEN_MARKER = /\A<!-- gh-issue-sync: \S+ -->/
  CLOSE_MARKER = %r{\A<!-- /gh-issue-sync: \S+ -->}

  # Text contract: the public module functions accept CRLF or LF and
  # normalize once on entry; the private line-scanning helpers assume
  # LF-only input.

  module_function

  # CRLF and lone CR both become LF: GitHub's web UI submits CRLF, and
  # a lone CR left un-normalized would smuggle line starts (marker
  # lines included) past every LF-splitting scanner, only to become
  # real lines after the next web-UI edit re-encodes them.
  def normalize(text)
    text.gsub(/\r\n?/, "\n")
  end

  # Parses the plan file's "## To-dos" section into
  # [{number:, checked:, text:}, ...]. Indented continuation lines fold
  # into the preceding item's text. Only top-level items are legal:
  # any checkbox line in the section that misses the strict
  # "- [ ] **N.** text" shape -- including an indented/nested checkbox
  # -- raises rather than being silently skipped or promoted, because a
  # skipped line would go permanently stale on the issue and a promoted
  # nested item would break the stable-numbering contract. Checkboxes
  # outside the section (acceptance criteria, examples) are none of our
  # business.
  def parse_plan_todos(plan_text)
    lines = normalize(plan_text).lines
    bounds = heading_bounds(lines)
    raise Error, "plan has no '## To-dos' section" unless bounds

    items = []
    lines[(bounds[0] + 1)...bounds[1]].each do |raw|
      line = raw.chomp
      if (m = TODO_LINE.match(line))
        items << { number: m[2].to_i, checked: m[1] == 'x', text: m[3] }
      elsif CHECKBOX_START.match?(line)
        raise Error, "malformed to-do line (expected top-level '- [ ] **N.** text'): #{line.strip}"
      elsif line.start_with?('  ') && !line.strip.empty? && items.any?
        items.last[:text] = "#{items.last[:text]} #{line.strip}"
      end
    end
    items
  end

  def render_section(items, slug:, heading_suffix: nil)
    heading = heading_suffix ? "## To-dos (#{heading_suffix})" : '## To-dos'
    lines = ["<!-- gh-issue-sync: #{slug} -->", heading]
    items.each do |item|
      lines << "- [#{item[:checked] ? 'x' : ' '}] **#{item[:number]}.** #{item[:text]}"
    end
    lines << "<!-- /gh-issue-sync: #{slug} -->"
    lines.join("\n")
  end

  # The one-call sync entry point: regenerates this slug's section from
  # the plan's items and returns [new_body, warnings], so the
  # never-silently-overwrite guarantee travels with the overwrite
  # instead of relying on every caller to remember the divergence
  # check.
  def sync_section(body, items, slug:, heading_suffix: nil)
    body = normalize(body)
    existing = matched_section!(body, slug)
    if existing && !checklist_section?(existing[0])
      raise Error, "section '#{slug}' holds arbitrary content, not a checklist; rename the plan file"
    end

    body_items = section_items(body, slug: slug)
    # First-ever sync on a pre-helper issue: the checklist about to be
    # adopted has no markers, and its hand-maintained state deserves
    # the same divergence warnings as a marked section's.
    body_items = adoption_items(body) if body_items.empty?
    divs = divergences(body_items, items)
    warnings =
      if divs.empty?
        []
      else
        ["#{divs.join('; ')} -- the plan file wins; absorb real GitHub-side changes into the plan, then re-sync"]
      end
    rendered = render_section(items, slug: slug, heading_suffix: heading_suffix)
    [upsert_section(body, rendered, slug: slug), warnings]
  end

  # Regenerates this slug's section in place; creates it (at the end of
  # the body) when absent. A marker-less "## To-dos" heading left by a
  # pre-helper flow is adopted -- replaced up to the next "##" heading
  # -- rather than duplicated; headings inside another slug's marker
  # pair or inside a fenced code block are never adoption targets.
  def upsert_section(body, rendered, slug:)
    body = normalize(body)
    pattern = section_pattern(slug)
    if body.match?(pattern)
      body.sub(pattern) { rendered }
    elsif (adopted = adopt_heading(body, rendered))
      adopted
    else
      append_body(body, rendered)
    end
  end

  # Reads this slug's section back out of a body, for divergence checks.
  def section_items(body, slug:)
    match = section_pattern(slug).match(normalize(body))
    return [] unless match

    match[0].each_line.filter_map do |line|
      m = TODO_LINE.match(line.chomp)
      m && { number: m[2].to_i, checked: m[1] == 'x', text: m[3] }
    end
  end

  # Anything on the GitHub side the plan does not carry is a human
  # signal the plan file never absorbed: a tick, an edited item text,
  # or a hand-added item. The plan is the source of truth, so the sync
  # overwrites -- but never silently.
  def divergences(body_items, plan_items)
    plan_by_number = plan_items.to_h { |item| [item[:number], item] }
    body_items.filter_map do |body_item|
      plan_item = plan_by_number[body_item[:number]]
      if plan_item.nil?
        "item #{body_item[:number]} exists only on GitHub"
      elsif body_item[:checked] && !plan_item[:checked]
        "item #{body_item[:number]} is ticked on GitHub but unchecked in the plan"
      elsif body_item[:text] != plan_item[:text]
        "item #{body_item[:number]}'s text differs between GitHub and the plan"
      end
    end
  end

  # The one spelling of the marker-line format; render and matching
  # both derive from these so they can never drift apart.
  def open_marker_line(slug)
    "<!-- gh-issue-sync: #{slug} -->"
  end

  def close_marker_line(slug)
    "<!-- /gh-issue-sync: #{slug} -->"
  end

  # Finds this slug's section and returns its MatchData (nil when the
  # body has none) -- refusing to proceed when the slug's markers do
  # not form exactly the matched pair. A marker orphaned by a hand
  # edit would otherwise make the next write append a duplicate
  # section, and the run after that swallow every line between the
  # orphan and a later close marker.
  def matched_section!(body, slug)
    opens = body.lines.count { |line| line.chomp == open_marker_line(slug) }
    closes = body.lines.count { |line| line.chomp == close_marker_line(slug) }
    match = section_pattern(slug).match(body)
    valid = match ? opens == 1 && closes == 1 : opens.zero? && closes.zero?
    unless valid
      raise Error, "issue body has unpaired '#{slug}' section markers " \
                   "(#{opens} open, #{closes} close); repair the body by hand first"
    end
    match
  end

  # Wraps arbitrary file content in this slug's marker pair, verbatim:
  # no generated heading (the content carries its own) and no item
  # parsing. Leading blank lines and trailing whitespace are trimmed,
  # first-line indentation is preserved, and the close marker always
  # lands on its own line.
  def render_content_section(content, slug:)
    content = normalize(content).sub(/\A(?:[ \t]*\n)+/, '').rstrip
    ["<!-- gh-issue-sync: #{slug} -->", content, "<!-- /gh-issue-sync: #{slug} -->"].join("\n")
  end

  # The idempotent replacement for the removed `append` subcommand:
  # regenerates this slug's content section in place, or creates it at
  # the end of the body when absent. Returns [new_body, outcome] where
  # outcome is :created, :replaced, or :unchanged. Never adopts a
  # marker-less '## To-dos' heading -- adoption is checklist-only --
  # and refuses to overwrite a checklist section, so a content slug
  # colliding with a plan basename fails loudly instead of corrupting
  # the checklist.
  def upsert_content_section(body, content, slug:)
    assert_valid_section_slug!(slug)
    raise Error, 'refusing to write an empty section (the content file is blank)' if content.strip.empty?

    assert_no_marker_lines!(content)
    assert_not_checklist_shaped!(content)
    body = normalize(body)
    rendered = render_content_section(content, slug: slug)
    existing = matched_section!(body, slug)
    return [append_body(body, rendered), :created] unless existing

    if checklist_section?(existing[0])
      raise Error, "section '#{slug}' is a checklist section; use checklist/reconcile, or pick another --slug"
    end
    return [body, :unchanged] if existing[0] == rendered

    [body.sub(section_pattern(slug)) { rendered }, :replaced]
  end

  # A section's kind is readable from its first non-blank content
  # line: checklist renders put the '## To-dos' heading directly under
  # the open marker, and content sections can never start with that
  # heading (assert_not_checklist_shaped! refuses it). Skipping blank
  # lines keeps the kind stable when a hand edit reflows whitespace
  # under the marker.
  def checklist_section?(section)
    first_content_line = section.each_line.lazy.drop(1).find { |line| !line.strip.empty? }
    first_content_line ? TODOS_HEADING.match?(first_content_line.chomp) : false
  end

  # The section kinds are told apart by their first non-blank line, so
  # content that opens with the checklist heading would be
  # misclassified on every later read -- locked against its own
  # re-runs and overwritable by a same-slug checklist sync. Refused
  # loudly instead, like the marker guard.
  def assert_not_checklist_shaped!(content)
    first_line = normalize(content).lines.find { |line| !line.strip.empty? }
    return content unless first_line && TODOS_HEADING.match?(first_line.chomp)

    raise Error, "content opens with a '## To-dos' heading, which marks checklist sections; " \
                 'reword its first line'
  end

  # Content is written verbatim, so a line shaped like either marker --
  # for ANY slug, even inside a fenced code block -- would corrupt
  # section detection body-wide. Line-anchored like the marker
  # scanners; mid-line mentions are legal.
  def assert_no_marker_lines!(content)
    normalize(content).each_line do |raw|
      line = raw.chomp
      next unless OPEN_MARKER.match?(line) || CLOSE_MARKER.match?(line)

      raise Error, "content contains a gh-issue-sync marker line (#{line.strip}); " \
                   'mention markers mid-line or indent them instead'
    end
    content
  end

  # Stricter than the checklist path's whitespace-only slug guard: a
  # typed --slug containing '>' (e.g. 'x-->') would close the HTML
  # comment early and leak into the rendered body.
  def assert_valid_section_slug!(slug)
    return slug if slug.match?(/\A[A-Za-z0-9._-]+\z/)

    raise Error, "--slug must contain only letters, digits, dots, underscores, and dashes, got #{slug.inspect}"
  end

  # Joins with exactly one blank line. Leading blank lines and trailing
  # whitespace are trimmed from the addition, but never the first
  # line's indentation -- an appended file may open with an indented
  # code block.
  def append_body(body, addition)
    body = normalize(body).rstrip
    addition = normalize(addition).sub(/\A(?:[ \t]*\n)+/, '').rstrip
    return "#{addition}\n" if body.empty?

    "#{body}\n\n#{addition}\n"
  end

  # The finish-phase reconcile must leave the public checklist in a
  # final state, and a bare unchecked box is not one: every item is
  # either done or explicitly deferred by the time an issue wraps up.
  def assert_reconcilable!(items)
    unchecked = items.reject { |item| item[:checked] }
    return items if unchecked.empty?

    listing = unchecked.map { |item| "  #{item[:number]}. #{item[:text]}" }.join("\n")
    raise Error,
          "reconcile refused: the plan still has bare unchecked to-dos -- " \
          "finish them or mark them deferred first:\n#{listing}"
  end

  def check_length!(body)
    return body if body.bytesize <= MAX_BODY_BYTES

    raise Error,
          "new body would be #{body.bytesize} bytes; GitHub's issue-body limit is #{MAX_BODY_BYTES} bytes (256 KiB)"
  end

  # Anchored to whole lines: markers are always rendered as full lines,
  # and an item text merely MENTIONING a marker string must not end the
  # match mid-line.
  def section_pattern(slug)
    open_marker = Regexp.escape("<!-- gh-issue-sync: #{slug} -->")
    close_marker = Regexp.escape("<!-- /gh-issue-sync: #{slug} -->")
    /^#{open_marker}$.*?^#{close_marker}$/m
  end

  # Slugs are embedded in the marker lines, whose scanners split on
  # whitespace; a slug containing whitespace would render markers they
  # can never re-recognize.
  def assert_valid_slug!(slug)
    return slug if slug.match?(/\A\S+\z/)

    raise Error, "slug must contain no whitespace, got #{slug.inspect} (rename the plan file)"
  end

  # The lines [start, stop) of the first "## To-dos" section: heading
  # at start, body up to (not including) the next "##" heading or end
  # of input. Skips headings inside fenced code blocks and inside any
  # line ranges passed as exclude (marker-wrapped sections during
  # adoption). Returns nil when no eligible heading exists.
  def heading_bounds(lines, exclude: [])
    in_fence = false
    start = nil
    lines.each_with_index do |raw, i|
      line = raw.chomp
      if line.lstrip.start_with?('```')
        in_fence = !in_fence
        next
      end
      next if in_fence

      if start.nil?
        start = i if TODOS_HEADING.match?(line) && exclude.none? { |range| range.cover?(i) }
      elsif line.start_with?('## ') || exclude.any? { |range| range.cover?(i) }
        return [start, i]
      end
    end
    start && [start, lines.length]
  end

  # Line-index ranges of every marker-delimited section in the body,
  # regardless of slug.
  def marked_line_ranges(lines)
    ranges = []
    open_index = nil
    lines.each_with_index do |raw, i|
      line = raw.chomp
      if open_index.nil? && OPEN_MARKER.match?(line)
        open_index = i
      elsif open_index && CLOSE_MARKER.match?(line)
        ranges << (open_index..i)
        open_index = nil
      end
    end
    ranges
  end

  # Items in the marker-less section adoption would target, read
  # leniently (non-matching lines are not this side's to police).
  def adoption_items(body)
    lines = normalize(body).lines
    bounds = heading_bounds(lines, exclude: marked_line_ranges(lines))
    return [] unless bounds

    lines[(bounds[0] + 1)...bounds[1]].filter_map do |raw|
      m = TODO_LINE.match(raw.chomp)
      m && { number: m[2].to_i, checked: m[1] == 'x', text: m[3] }
    end
  end

  def adopt_heading(body, rendered)
    lines = body.lines
    bounds = heading_bounds(lines, exclude: marked_line_ranges(lines))
    return nil unless bounds

    start, stop = bounds
    before = lines[0...start].join.rstrip
    after = lines[stop..].join.strip
    result = before.empty? ? '' : "#{before}\n\n"
    result += "#{rendered.rstrip}\n"
    result += "\n#{after}\n" unless after.empty?
    result
  end

  USAGE = <<~TXT
    gh-issue-sync -- GitHub issue-body read-modify-write helper (uses gh)

    gh-issue-sync section NNN --file <md> --slug <key> [--repo owner/name]
        Upsert the file's content, verbatim, into its own
        marker-delimited section of the issue body, keyed by --slug:
        created at the end of the body when absent, replaced in place
        on re-run. Idempotent. The file is the source of truth --
        hand-edits inside the section are overwritten without warning.
        Refused: empty files, content containing a line shaped like a
        sync marker (mention markers mid-line instead), and a --slug
        that names an existing checklist section.

    gh-issue-sync checklist NNN --plan <plan.md> [--heading <slug>] [--repo owner/name]
        Regenerate the issue body's checklist section from the plan
        file's '## To-dos' items (strict top-level '- [ ] **N.** text'
        shape). The section is delimited by
        <!-- gh-issue-sync: <slug> --> markers (slug = the plan file's
        basename minus .md); it is created when absent, and a marker-less
        pre-helper '## To-dos' heading is adopted, not duplicated.
        --heading adds a visible '## To-dos (<slug>)' suffix for
        multi-plan issues. Idempotent. Anything on the GitHub side the
        plan lacks -- a tick, an edited item text, a hand-added item --
        is overwritten with a warning: the plan file is the source of
        truth, so absorb real GitHub-side changes into it and re-sync.

    gh-issue-sync reconcile NNN --plan <plan.md> [--heading <slug>] [--repo owner/name]
        The finish-phase sync: same regeneration, but refuses to run
        while the plan still has bare unchecked to-dos -- every item
        must be checked (done, or checked with a deferred-to note) so
        the public checklist never ends stale.

    The body is re-fetched immediately before every write (GitHub has
    no compare-and-swap). Fetches go through JSON.parse, never jq -r,
    so bodies round-trip byte-exact; CRLF from web-UI edits is
    normalized to LF.
  TXT

  class CLI
    def self.run(argv)
      new.run(argv)
    end

    def run(argv)
      command = argv.shift
      case command
      when 'append'
        raise Error, "append was replaced by the idempotent 'section NNN --file <md> --slug <key>'"
      when 'section'   then section(argv)
      when 'checklist' then sync(argv, reconcile: false)
      when 'reconcile' then sync(argv, reconcile: true)
      when nil, 'help', '--help', '-h' then puts USAGE
      else
        warn "gh-issue-sync: unknown subcommand #{command.inspect}"
        warn USAGE
        exit 1
      end
    rescue Error => e
      abort "gh-issue-sync: #{e.message}"
    end

    private

    def section(argv)
      options = {}
      rest = parse_options(argv, 'section NNN --file <md> --slug <key> [--repo owner/name]') do |o|
        o.on('--file PATH', 'markdown file whose content fills the section') { |v| options[:file] = v }
        o.on('--slug KEY', 'key naming the marker-delimited section') { |v| options[:slug] = v }
        o.on('--repo NAME', 'owner/name pass-through to gh') { |v| options[:repo] = v }
      end
      number = issue_number(rest)
      path = options[:file]
      raise Error, 'section requires --file <md>' unless path
      raise Error, 'section requires --slug <key>' unless options[:slug]
      raise Error, "file not found: #{path}" unless File.exist?(path)

      body = fetch_body(number, options[:repo])
      new_body, outcome = GhIssueSync.upsert_content_section(body, File.read(path), slug: options[:slug])
      if outcome == :unchanged
        puts "Section #{options[:slug]} on issue ##{number} is already up to date (nothing written)"
      else
        write_body(number, options[:repo], new_body)
        puts "#{outcome == :created ? 'Created' : 'Replaced'} section #{options[:slug]} on issue ##{number}"
      end
    end

    def sync(argv, reconcile:)
      subcommand = reconcile ? 'reconcile' : 'checklist'
      options = {}
      rest = parse_options(argv, "#{subcommand} NNN --plan <plan.md> [--heading <slug>] [--repo owner/name]") do |o|
        o.on('--plan PATH', 'plan file whose To-dos drive the sync') { |v| options[:plan] = v }
        o.on('--heading SLUG', 'visible heading suffix for multi-plan issues') { |v| options[:heading] = v }
        o.on('--repo NAME', 'owner/name pass-through to gh') { |v| options[:repo] = v }
      end
      number = issue_number(rest)
      plan_path = options[:plan]
      raise Error, "#{subcommand} requires --plan <plan.md>" unless plan_path
      raise Error, "plan file not found: #{plan_path}" unless File.exist?(plan_path)

      items = GhIssueSync.parse_plan_todos(File.read(plan_path))
      raise Error, "the plan's To-dos section has no items: #{plan_path}" if items.empty?

      GhIssueSync.assert_reconcilable!(items) if reconcile
      slug = GhIssueSync.assert_valid_slug!(File.basename(plan_path, '.md'))

      body = fetch_body(number, options[:repo])
      new_body, warnings = GhIssueSync.sync_section(body, items, slug: slug, heading_suffix: options[:heading])
      warnings.each { |warning| warn "gh-issue-sync: warning: #{warning}" }
      write_body(number, options[:repo], new_body)

      done = items.count { |item| item[:checked] }
      puts "#{reconcile ? 'Reconciled' : 'Synced'} #{slug} on issue ##{number} (#{done} of #{items.length} checked)"
    end

    def parse_options(argv, banner)
      parser = OptionParser.new do |o|
        o.banner = "Usage: gh-issue-sync #{banner}"
        yield o
      end
      parser.parse(argv)
    rescue OptionParser::ParseError => e
      raise Error, e.message
    end

    def issue_number(rest)
      number = rest.first
      raise Error, 'missing issue number' unless number
      raise Error, "issue number must be digits, got #{number.inspect}" unless number.match?(/\A\d+\z/)

      number
    end

    def fetch_body(number, repo)
      output = gh(['issue', 'view', number, '--json', 'body'], repo)
      GhIssueSync.normalize(JSON.parse(output)['body'].to_s)
    end

    def write_body(number, repo, body)
      GhIssueSync.check_length!(body)
      Tempfile.create('gh-issue-sync-body') do |file|
        file.write(body)
        file.flush
        gh(['issue', 'edit', number, '--body-file', file.path], repo)
      end
    end

    def gh(args, repo)
      command = ['gh', *args]
      command += ['--repo', repo] if repo
      stdout, stderr, status = Open3.capture3(*command)
      raise Error, "gh #{args.first(2).join(' ')} failed: #{stderr.strip}" unless status.success?

      stdout
    rescue Errno::ENOENT
      raise Error, 'gh not found on PATH (install the GitHub CLI)'
    end
  end
end

GhIssueSync::CLI.run(ARGV) if $PROGRAM_NAME == __FILE__
